# SentinelX EDR - Environment Variables
# =======================================
# Copy this file to .env and customize values
#
# Required: None (all have defaults for development)
# Recommended: At least one AI API key for investigations

# ── Application ─────────────────────────────────────────────
APP_NAME=SentinelX EDR
DEBUG=true
DEMO_MODE=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ────────────────────────────────────────────────
# SQLite (default - zero config):
DATABASE_URL=sqlite:///./sentinelx.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://sentinelx:password@localhost:5432/sentinelx

# ── AI Providers ────────────────────────────────────────────
# Get a free Gemini key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Get a free OpenRouter key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Threat Intelligence Feeds (all optional) ────────────────
# AbuseIPDB: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=
# AlienVault OTX: https://otx.alienvault.com/api
OTX_API_KEY=
# MalwareBazaar: No key needed (public API)
TI_SYNC_INTERVAL_HOURS=4

# ── Detection Engine ────────────────────────────────────────
SIGMA_RULES_DIR=./app/data/sigma_rules
PLUGIN_DIR=./app/plugins/examples
COLLECTION_INTERVAL_SECONDS=60
MAX_EVENTS_PER_WINDOW=100

# ── Security ────────────────────────────────────────────────
# If set, all API endpoints require this key in X-API-Key header
API_KEY=
# JWT secret for dashboard authentication
JWT_SECRET=sentinelx-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480

# ── Agent ───────────────────────────────────────────────────
AGENT_HEARTBEAT_TIMEOUT_SECONDS=300
